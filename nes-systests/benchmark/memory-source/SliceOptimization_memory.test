# name: benchmark/SliceOptimization_memory.test
# description: Slice-store stress queries for scripts/benchmarking/slice_optimization_benchmarks.
#   Both use a 1 second slide so a large number of slices stay concurrently active, which is what the
#   preemptive_create_horizon_ms / recycle_pool_size knobs target. bid_6GB.csv spans ~6.4h, so the
#   1 DAY aggregation holds ~23000 active slices and the 1 HOUR join holds ~3600.
# groups: [benchmark, large, Aggregation, Join]

# bid timestamps are epoch milliseconds; window units (SEC/HOUR/DAY) map straight through.
CREATE LOGICAL SOURCE bid(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price FLOAT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR bid TYPE Memory;
ATTACH FILE large/nexmark/bid_6GB.csv

# Second view over the same file for the self-join. Keeps `timestamp` (the window field) but renames
# the rest to avoid ambiguity in the ON clause and projection.
CREATE LOGICAL SOURCE bidJoin(timestamp UINT64 NOT NULL, auctionId2 INT32 NOT NULL, bidder2 INT32 NOT NULL, price2 FLOAT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR bidJoin TYPE Memory;
ATTACH FILE large/nexmark/bid_6GB.csv

CREATE SINK sliceAggSink(bid.start UINT64 NOT NULL, bid.end UINT64 NOT NULL, bid.auctionId INT32 NOT NULL, bid.num UINT64 NOT NULL) TYPE Void;
CREATE SINK sliceJoinSink(bidbidJoin.start UINT64 NOT NULL, bidbidJoin.end UINT64 NOT NULL, bid.auctionId INT32 NOT NULL, bid.bidder INT32 NOT NULL, bid.price FLOAT64 NOT NULL, bidJoin.auctionId2 INT32 NOT NULL, bidJoin.bidder2 INT32 NOT NULL, bidJoin.price2 FLOAT64 NOT NULL) TYPE Void;


# Query 01 - slice-heavy aggregation
### SIZE 1 DAY -> ~23000 active slices over the ~6.4h span; lower to 1 HOUR for ~3600.
SELECT start, end, auctionId, COUNT(auctionId) AS num
FROM bid
GROUP BY auctionId
WINDOW SLIDING(timestamp, SIZE 1 DAY, ADVANCE BY 1 SEC)
INTO sliceAggSink;
----


# Query 02 - slice-heavy hash join (self-join on the same file)
### Join on price (near-unique, bounded fan-out). bidder/auctionId are heavily skewed and would
### cartesian-explode. SIZE 1 HOUR -> ~3600 slices; join slices store tuples on both sides, so keep
### the window smaller than the aggregation.
SELECT start, end, auctionId, bidder, price, auctionId2, bidder2, price2
FROM (SELECT * FROM bid)
INNER JOIN (SELECT * FROM bidJoin) ON price = price2
WINDOW SLIDING(timestamp, SIZE 1 HOUR, ADVANCE BY 1 SEC)
INTO sliceJoinSink;
----


# Lighter variants over the 1GB google-cluster trace (vs the 6GB bid file) so the sweep fits a small
# Docker VM. Same 1 second slide -> slice-store stress, but fewer tuples to load. Active-slice count is
# min(SIZE/ADVANCE, span/ADVANCE): if the 1G file's time span is shorter than SIZE, lower SIZE to keep
# the window from covering the whole stream. Schema matches the original-data source in
# milestone/ClusterMonitoring_memory.test (FLOAT64 metrics, BOOLEAN constraints).
CREATE LOGICAL SOURCE cm(creationTS UINT64 NOT NULL, jobId UINT64 NOT NULL, taskId UINT64 NOT NULL, machineId INT64 NOT NULL, eventType INT16 NOT NULL, userId INT16 NOT NULL, category INT16 NOT NULL, priority INT16 NOT NULL, cpu FLOAT64 NOT NULL, ram FLOAT64 NOT NULL, disk FLOAT64 NOT NULL, constraints BOOLEAN NOT NULL);
CREATE PHYSICAL SOURCE FOR cm TYPE Memory;
ATTACH FILE large/cluster_monitoring/google-cluster-data-original_1G.csv

# Second view over the same file for the self-join; metric/id fields renamed to avoid ON-clause ambiguity.
CREATE LOGICAL SOURCE cmJoin(creationTS UINT64 NOT NULL, jobId2 UINT64 NOT NULL, taskId2 UINT64 NOT NULL, machineId2 INT64 NOT NULL, eventType2 INT16 NOT NULL, userId2 INT16 NOT NULL, category2 INT16 NOT NULL, priority2 INT16 NOT NULL, cpu2 FLOAT64 NOT NULL, ram2 FLOAT64 NOT NULL, disk2 FLOAT64 NOT NULL, constraints2 BOOLEAN NOT NULL);
CREATE PHYSICAL SOURCE FOR cmJoin TYPE Memory;
ATTACH FILE large/cluster_monitoring/google-cluster-data-original_1G.csv

CREATE SINK cmAggSink(cm.start UINT64 NOT NULL, cm.end UINT64 NOT NULL, cm.jobId UINT64 NOT NULL, cm.totalCpu FLOAT64 NOT NULL) TYPE Void;
CREATE SINK cmJoinSink(cmcmJoin.start UINT64 NOT NULL, cmcmJoin.end UINT64 NOT NULL, cm.jobId UINT64 NOT NULL, cm.cpu FLOAT64 NOT NULL, cmJoin.jobId2 UINT64 NOT NULL, cmJoin.cpu2 FLOAT64 NOT NULL) TYPE Void;


# Query 03 - slice-heavy aggregation over the 1GB cluster trace
### SIZE 1 HOUR @ 1 SEC slide -> up to ~3600 active slices. eventType==3 (task-finish) thins the input.
SELECT start, end, jobId, SUM(cpu) AS totalCpu
FROM cm
WHERE eventType == INT16(3)
GROUP BY jobId
WINDOW SLIDING(creationTS, SIZE 1 HOUR, ADVANCE BY 1 SEC)
INTO cmAggSink;
----


# Query 04 - slice-heavy hash join over the 1GB cluster trace (self-join on the same file)
### Join on cpu (FLOAT64, bounded fan-out like price above). SIZE 10 MIN @ 1 SEC slide -> ~600 slices;
### join slices hold both sides, so keep the window smaller than the aggregation.
SELECT start, end, jobId, cpu, jobId2, cpu2
FROM (SELECT * FROM cm)
INNER JOIN (SELECT * FROM cmJoin) ON cpu = cpu2
WINDOW SLIDING(creationTS, SIZE 10 MIN, ADVANCE BY 1 SEC)
INTO cmJoinSink;
----
